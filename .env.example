# ── OpenRouter (Image Generation) ──
OPENROUTER_API_KEY=your-openrouter-api-key
IMAGE_GEN_MODEL=google/gemini-2.5-flash-preview-image-generation

# ── Prompt Agent LLM ──
PROMPT_AGENT_API_KEY=your-deepseek-or-openrouter-key
PROMPT_AGENT_BASE_URL=https://openrouter.ai/api/v1/chat/completions
PROMPT_AGENT_MODEL=deepseek/deepseek-chat

# ── Google Drive ──
GDRIVE_SERVICE_ACCOUNT_FILE=service-account.json
GDRIVE_FOLDER_ID=your-drive-folder-id

# ── Pipeline Defaults ──
LIFESTYLE_IMAGE_COUNT=3
MAX_SCRAPED_IMAGES=6
MIN_TOTAL_GALLERY_IMAGES=6
